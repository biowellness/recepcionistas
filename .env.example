# =========================================================================
# BioWellness Recepción — variables de entorno (ejemplo)
# Copiar a `.env` y completar. NUNCA commitear el .env real.
# =========================================================================

# --- Medplum (arrancamos en Medplum Cloud; portable a self-hosted) ---
# Base URL del servidor Medplum. Cloud: https://api.medplum.com/
MEDPLUM_BASE_URL=https://api.medplum.com/
# Credenciales de ClientApplication (client credentials) para seed y bots.
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=
# Project ID (opcional, para CLI multi-proyecto)
MEDPLUM_PROJECT_ID=

# --- Tipo de cambio por defecto (ARS/USD). Configurable por el admin. ---
# Valor de referencia del brief. Se almacena además como recurso FHIR (ver seed).
BW_TC_DEFAULT=1450

# --- Twilio (WhatsApp Business API) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número WhatsApp Business habilitado (formato whatsapp:+54911...)
TWILIO_WHATSAPP_FROM=

# --- Email transaccional: AWS SES ---
# El email se envía con medplum.sendEmail(), que usa el proveedor configurado en
# el servidor Medplum (AWS SES). No hacen falta credenciales de SES en el código;
# se configuran en el servidor Medplum. Solo el remitente verificado:
SES_FROM_EMAIL=

# --- MercadoPago (cobros; tokeniza tarjetas, no almacenamos datos de tarjeta) ---
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# --- URLs base (Project Secrets de Medplum, leídas por los bots) ---
# App de recepción (back_urls de MercadoPago, etc.)
APP_BASE_URL=https://recepcion.medplum.com.ar
# Portal del paciente (FooMedical). Destino del link de invitación al portal.
PORTAL_BASE_URL=https://bio.medplum.com.ar
