# Variables del FRONT de recepción (expuestas al navegador vía envPrefix de Vite).
# ⚠️ Solo valores públicos. NUNCA pongas secretos acá (p. ej. MEDPLUM_CLIENT_SECRET):
# con el prefijo MEDPLUM_ quedarían embebidos en el bundle del cliente.

# URL de la API de Medplum (Cloud BioWellness):
MEDPLUM_BASE_URL=https://api.medplum.com.ar/

# Login con Google (Gmail): client ID público de Google OAuth (app web).
# Requisitos: (1) registrar ESTE client ID en el proyecto Medplum (Google auth);
# (2) en Google Cloud, autorizar https://recepcion.medplum.com.ar como
# "Authorized JavaScript origin". Solo entran las cuentas habilitadas como usuario
# en el proyecto (p. ej. recepcion@biowellness.ar).
GOOGLE_CLIENT_ID=

# reCAPTCHA (opcional): site key pública.
# RECAPTCHA_SITE_KEY=
