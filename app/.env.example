# Variables del FRONT de recepción (expuestas al navegador vía envPrefix de Vite).
# ⚠️ Solo valores públicos. NUNCA pongas secretos acá (p. ej. MEDPLUM_CLIENT_SECRET):
# con el prefijo MEDPLUM_ quedarían embebidos en el bundle del cliente.

# URL de la API de Medplum (Cloud BioWellness):
MEDPLUM_BASE_URL=https://api.medplum.com.ar/

# Login con Google (opcional): client ID público de Google OAuth.
# GOOGLE_CLIENT_ID=

# reCAPTCHA (opcional): site key pública.
# RECAPTCHA_SITE_KEY=
